{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/client/src/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/client/src/**/*.ts",
    "src/client/src/**/*.tsx",
    "src/shared/**/*.ts",
    "vite.config.ts"
  ]
}
