{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "outDir": "dist/server",
    "rootDir": "src",
    "declaration": false,
    "emitDeclarationOnly": false
  },
  "include": [
    "src/server/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
